<div class="container-fluid local-dashboard-v3">

    <div class="dashboard-header mb-4">
        <h2 class="dashboard-title mb-0">Docentes</h2>
    </div>

    <div class="dashboard-filters d-flex justify-content-end flex-wrap gap-2 mb-3">

        <!-- Filtro días -->
        <div class="filter-control">
            <select id="filter-days" class="form-select form-select-sm">
                <option value="7" {{#is7}}selected{{/is7}}>Últimos 7 días</option>
                <option value="30" {{#is30}}selected{{/is30}}>Últimos 30 días</option>
                <option value="90" {{#is90}}selected{{/is90}}>Últimos 90 días</option>
            </select>
        </div>

    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">

        {{#kpis}}
        <div class="col-xl-3 col-md-6">

            <div class="kpi">

                <div class="kpi-top">
                    <span class="kpi-label">{{label}}</span>
                </div>

                <div class="kpi-middle">
                    <div class="kpi-value">{{value}}</div>
                </div>

                {{#show_trend}}
                <div class="kpi-bottom">

                    <span class="kpi-trend {{trend_class}}">
                        {{#trend_label}}
                            {{#up}}▲{{/up}}
                            {{#down}}▼{{/down}}
                            {{#equal}}●{{/equal}}
                        {{/trend_label}}

                        {{trend}}%
                    </span>

                </div>
                {{/show_trend}}

            </div>

        </div>
        {{/kpis}}

    </div>

    <!-- INSIGHTS -->
    <div class="dashboard-insights mt-4">

        {{#insights}}
        <div class="insight-card {{type}}">

            <div class="insight-icon">
                {{#is_danger}}<i class="fa fa-circle-exclamation"></i>{{/is_danger}}
                {{#is_warning}}<i class="fa fa-triangle-exclamation"></i>{{/is_warning}}
                {{#is_info}}<i class="fa fa-circle-info"></i>{{/is_info}}
            </div>

            <div class="insight-body">

                <div class="insight-title">
                    {{#is_danger}}Atención crítica{{/is_danger}}
                    {{#is_warning}}Revisión recomendada{{/is_warning}}
                    {{#is_info}}Información{{/is_info}}
                </div>

                <div class="insight-message">
                    {{message}}
                </div>

            </div>

        </div>
        {{/insights}}

    </div>

     <!-- Gráfica -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card custom-card mb-4">

                <div class="card-header custom-card-header">
                    <h6 class="m-0 font-weight-bold">
                        Actividad docente en el tiempo
                    </h6>
                    <small class="text-muted">
                        Interacciones de docentes en los últimos {{days}} días
                    </small>
                </div>

                <div class="card-body">
                    <div id="teacherActivityChart"></div>
                </div>

            </div>
        </div>
         <div class="col-lg-6 col-12">
            <div class="card custom-card mb-4">

                <div class="card-header custom-card-header">
                    <h6 class="m-0 font-weight-bold">
                        Docentes activos por día
                    </h6>
                    <small class="text-muted">
                        Participación diaria de docentes en el periodo
                    </small>
                </div>

                <div class="card-body">
                    <div id="teacherActiveDailyChart"></div>
                </div>

            </div>
        </div>
          <div class="col-lg-6 col-12">
            <div class="card custom-card mb-4">

                <div class="card-header custom-card-header">
                    <h6 class="m-0 font-weight-bold">
                        Intervención por curso
                    </h6>
                    <small class="text-muted">
                        Cursos con más actividad docente (Top)
                    </small>
                </div>

                <div class="card-body">
                    <div id="teacherCourseInterventionChart"></div>
                </div>

            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">

            <div class="card custom-card mb-4">

                <div class="card-header custom-card-header">
                    <h6 class="m-0 font-weight-bold">
                        Ranking de docentes
                    </h6>
                    <small class="text-muted">
                        Actividad y desempeño docente en los últimos {{days}} días
                    </small>
                </div>

                <div class="card-body">

                    {{{table_teachers}}}

                </div>

            </div>

        </div>
    </div>

</div>